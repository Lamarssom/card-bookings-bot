generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CardType {
  YELLOW_CARD
  RED_CARD
}

enum League {
  EPL
  BUNDESLIGA
  SERIE_A
  LALIGA
  LIGUE_1
}

model Fixture {
  id         Int      @id @default(autoincrement())
  league     League
  div        String?
  homeTeam   String
  awayTeam   String
  date       DateTime
  leagueId   Int?
  leagueName String?
  round      String?
  status     String   @default("SCHEDULED")
  referee    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  homeYellowCards Int?     @default(0)
  awayYellowCards Int?     @default(0)
  homeRedCards    Int?     @default(0)
  awayRedCards    Int?     @default(0)

  @@unique([league, homeTeam, awayTeam, date])
}

model Card {
  id         Int      @id @default(autoincrement())
  fixtureId  Int
  match      String
  leagueId   Int?
  leagueName String?
  date       DateTime
  homeTeam   String?
  awayTeam   String?
  team       String
  player     String
  cardType   CardType
  minute     Int
  extraTime  Int?
  matchday   Int?
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([fixtureId, player, minute])
  @@index([leagueId, matchday, date(sort: Desc)])
  @@index([team, leagueId, matchday])
  @@index([homeTeam, leagueId])
  @@index([awayTeam, leagueId])
  @@index([date(sort: Desc)])
}

model RefereeStats {
  id            Int    @id @default(autoincrement())
  referee       String @unique
  matches       Int
  avgYellow     Float
  avgRed        Float
  avgTotalCards Float   // already using 1.5 weighting for reds
}

model TeamAggression {
  id              Int    @id @default(autoincrement())
  team            String @unique
  yellowPerGame   Float
  redPerGame      Float
  aggressionIndex Float   // 1.0 = average, 1.25 = aggressive
}

model DerbyIntensity {
  id       Int    @id @default(autoincrement())
  homeTeam String
  awayTeam String
  intensity Float  // 1.0 = normal, 1.35 = high-card derby
  @@unique([homeTeam, awayTeam])
}