{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/telegraf/.*",
      "dest": "src/index.ts"
    },
    {
      "src": "/.*",
      "dest": "src/index.ts"
    }
  ],
  "functions": {
    "src/index.ts": {
      "includeFiles": "node_modules/.prisma/client/**"
    }
  }
}